{
  "_meta": {
    "title": "Wiener Linien Accessibility Model Dataset v2",
    "description": "Three-layer accessibility dataset: (1) per-station physical traits by stop_type, (2) per-vehicle-type traits for Vehicle class, (3) line-to-vehicle-type assignments with wait-factor model. Cross-validated against wienerlinien-ogd-haltestellen.csv, wienerlinien-ogd-linien.csv, and wienerlinien-ogd-steige.csv.",
    "sources": [
      "https://www.wienerlinien.at/barrierefreiheit",
      "https://www.wienerlinien.at/web/wl-en/accessible-mobility",
      "https://www.wienerlinien.at/barrierefreiheit/stationen-mit-mittelbahnsteig",
      "https://www.wienerlinien.at/documents/2424499/7691181/Folder_Barrierefrei_2023.pdf",
      "https://www.wien.gv.at/verkehr/oeffentlich/barrierefreiheit.html",
      "https://www.wien.info/en/travel-info/accessible-vienna/accessible-public-transport-338230",
      "https://de.wikipedia.org/wiki/Straßenbahn_Wien_Type_E",
      "https://de.wikipedia.org/wiki/Ultra_Low_Floor",
      "https://de.wikipedia.org/wiki/U-Bahn_Wien_X",
      "https://de.wikipedia.org/wiki/Straßenbahn_Wien_Type_D_(2017)",
      "wienerlinien-ogd-haltestellen.csv (1959 stops)",
      "wienerlinien-ogd-linien.csv (197 lines)",
      "wienerlinien-ogd-steige.csv (7362 platforms)"
    ],
    "last_updated": "2026-03-22",
    "data_vintage": "Late 2025 / early 2026 estimates",
    "version": 2,
    "changelog_v2": [
      "Fixed 'Kaisermühlen VIC' -> 'Kaisermühlen-VIC' to match CSV naming",
      "Fixed 'Südtiroler Platz Hauptbahnhof' -> 'Hauptbahnhof' to match CSV naming",
      "Removed phantom tram line 27 (not present in OGD CSV data)",
      "Replaced probability_accessible with three-field wait-factor model: line_accessible, guaranteed_accessible_vehicle, expected_wait_factor",
      "Cross-validated all 28 tram lines, 5 U-Bahn lines, 112 bus lines against CSV"
    ],
    "notes": [
      "No official structured accessibility dataset exists from Wiener Linien.",
      "OGD CSV files contain NO accessibility columns whatsoever.",
      "GTFS stops.txt has NO wheelchair_boarding column.",
      "Station-level data uses blanket rules by stop_type since per-station features are uniform within categories.",
      "The haltestellen.csv TYP field is 'stop' for all 1959 rows — stop_type must be inferred by joining through steige.csv to linien.csv VERKEHRSMITTEL."
    ],
    "wait_factor_model": {
      "description": "For lines with mixed accessible/inaccessible vehicles, expected_wait_factor models the average number of headways a wheelchair user must wait. Formula: expected_wait_factor = 1.0 / fraction_accessible_vehicles. Actual extra wait = (expected_wait_factor - 1.0) * base_headway_minutes. A value of 1.0 means every vehicle is accessible (no extra wait).",
      "example": "U1 at peak runs every 4 min. With wait_factor=1.43, expected wait is 1.43 * 4 = 5.7 min instead of 4 min. Extra wait = 1.7 min."
    }
  },


