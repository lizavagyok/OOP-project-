  "line_vehicle_assignments": {
    "_description": "Which vehicle_type_ids serve which lines. Cross-validated against wienerlinien-ogd-linien.csv (28 ptTram lines, 5 ptMetro lines, 112+ ptBusCity lines). Uses wait-factor model instead of probability.",
    "_wait_factor_formula": "expected_wait_factor = 1.0 / fraction_accessible_vehicles. Extra wait = (expected_wait_factor - 1.0) * headway_minutes. A factor of 1.0 means every vehicle is accessible.",
    "_fraction_notes": "fraction_accessible is estimated from fleet composition data (number of E2 sets vs total runs on a line, Silberpfeil vs V/X-Wagen ratio). Not officially published — derived from Wikipedia fleet counts and Wiener Linien press releases.",

    "ubahn": {
      "U1": {
        "vehicle_types": ["silberpfeil_u", "v_wagen"],
        "line_accessible": true,
        "guaranteed_accessible_vehicle": false,
        "fraction_accessible": 0.70,
        "expected_wait_factor": 1.43,
        "notes": "Mixed Silberpfeil and V-Wagen. V-Wagen indicated by underscore on platform displays. X-Wagen expected eventually."
      },
      "U2": {
        "vehicle_types": ["v_wagen", "x_wagen"],
        "line_accessible": true,
        "guaranteed_accessible_vehicle": true,
        "fraction_accessible": 1.0,
        "expected_wait_factor": 1.0,
        "notes": "V-Wagen and X-Wagen only. Silberpfeil phased out from U2."
      },
      "U3": {
        "vehicle_types": ["silberpfeil_u", "v_wagen", "x_wagen"],
        "line_accessible": true,
        "guaranteed_accessible_vehicle": false,
        "fraction_accessible": 0.80,
        "expected_wait_factor": 1.25,
        "notes": "All three types in service. X-Wagen entered U3 first (June 2023). Some Silberpfeil U2-subtype still present from Erdberg depot."
      },
      "U4": {
        "vehicle_types": ["silberpfeil_u", "v_wagen"],
        "line_accessible": true,
        "guaranteed_accessible_vehicle": false,
        "fraction_accessible": 0.65,
        "expected_wait_factor": 1.54,
        "notes": "Mixed Silberpfeil and V-Wagen. V-Wagen indicated by underscore on platform displays."
      },
      "U6": {
        "vehicle_types": ["t_t1_u6"],
        "line_accessible": true,
